#!/usr/bin/env sh
# chezmoi-get-secret - Fetch a secret from Proton Pass CLI
# Usage: chezmoi-get-secret <item-title> [private-key|public-key|password|credential|api-key|note]
set -eu

TITLE="${1:?Usage: chezmoi-get-secret <item-title> [field]}"
FIELD="${2:-private-key}"

json=$(pass-cli item view --vault-name CLI --item-title "$TITLE" --output json 2>/dev/null) || {
  echo "ERROR: pass-cli not authenticated or item not found: $TITLE" >&2
  exit 1
}

case "$FIELD" in
  private-key)
    printf '%s' "$json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['item']['content']['content']['SshKey']['private_key'])"
    ;;
  public-key)
    printf '%s' "$json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['item']['content']['content']['SshKey']['public_key'])"
    ;;
  password|credential|api-key)
    printf '%s' "$json" | python3 -c "import sys,json
d=json.load(sys.stdin)
content=d['item']['content']
payload=content.get('content') or {}
keys=('password','credential','api_key','apiKey','APIキー')
def find(value):
    if isinstance(value, dict):
        for key in keys:
            if key in value and value[key]:
                return value[key]
        for child in value.values():
            found=find(child)
            if found:
                return found
    elif isinstance(value, list):
        for child in value:
            found=find(child)
            if found:
                return found
    return ''
print(find(payload) or content.get('note') or '')"
    ;;
  note)
    printf '%s' "$json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['item']['content']['note'] or '')"
    ;;
  *)
    echo "ERROR: Unknown field: $FIELD (use private-key, public-key, password, credential, api-key, or note)" >&2
    exit 1
    ;;
esac
