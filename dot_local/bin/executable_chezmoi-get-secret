#!/usr/bin/env sh
# chezmoi-get-secret - Fetch a secret from Proton Pass CLI
# Usage: chezmoi-get-secret <item-title> [field]
set -eu

TITLE="${1:?Usage: chezmoi-get-secret <item-title> [field]}"
FIELD="${2:-private-key}"

view_field() {
  pass-cli item view --vault-name CLI --item-title "$TITLE" --field "$1" 2>/dev/null
}

case "$FIELD" in
  private-key)
    view_field private_key
    ;;
  public-key)
    view_field public_key
    ;;
  password|credential|api-key)
    for candidate in "$FIELD" password credential api_key apiKey "APIキー" "認証情報" token user; do
      if value=$(view_field "$candidate"); then
        printf '%s\n' "$value"
        exit 0
      fi
    done
    echo "ERROR: pass-cli field not found: $TITLE/$FIELD" >&2
    exit 1
    ;;
  note)
    pass-cli item view --vault-name CLI --item-title "$TITLE" --output json 2>/dev/null \
      | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['item']['content'].get('note') or '')"
    ;;
  *)
    view_field "$FIELD"
    ;;
esac
