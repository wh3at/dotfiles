if [ -f ~/.profile ]; then
    source ~/.profile
fi

# Load ~/.zprofile once from interactive shells that are not login shells
if [[ -o interactive ]] && [[ ! -o login ]]; then
  if [[ -z "${__ZPROFILE_LOADED-}" ]]; then
    __ZPROFILE_LOADED=1
    [[ -r ~/.zprofile ]] && source ~/.zprofile
  fi
fi

# Lines configured by zsh-newuser-install
HISTFILE=~/.histfile
HISTSIZE=1000
SAVEHIST=1000
bindkey -e
# End of lines configured by zsh-newuser-install

# The following lines were added by compinstall
zstyle :compinstall filename '/home/ubuntu/.zshrc'

autoload -Uz compinit
compinit
# End of lines added by compinstall

# WP-CLI completion
autoload bashcompinit
bashcompinit
source ~/.wp-completion.bash

# Added by Zinit's installer
if [[ ! -f $HOME/.local/share/zinit/zinit.git/zinit.zsh ]]; then
    print -P "%F{33} %F{220}Installing %F{33}ZDHARMA-CONTINUUM%F{220} Initiative Plugin Manager (%F{33}zdharma-continuum/zinit%F{220})…%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$HOME/.local/share/zinit/zinit.git" && \
        print -P "%F{33} %F{34}Installation successful.%f%b" || \
        print -P "%F{160} The clone has failed.%f%b"
fi

source "$HOME/.local/share/zinit/zinit.git/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit
# End of Zinit's installer chunk

# Zinit's config
## プロンプトテーマ sindresorhus/pure
zi ice pick"async.zsh" src"pure.zsh"
zi light sindresorhus/pure
## 略語展開
zinit light olets/zsh-abbr
## インタラクティブな補完
zinit light zsh-users/zsh-autosuggestions
## autosuggestionsで略語展開を表示
zinit light olets/zsh-autosuggestions-abbreviations-strategy
ZSH_AUTOSUGGEST_STRATEGY=( abbreviations $ZSH_AUTOSUGGEST_STRATEGY )
## シンタックスハイライト
zinit light zdharma-continuum/fast-syntax-highlighting
# End of Zinit's config

# PATH
export PATH="$HOME/.local/share/mise/shims:$PATH"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
export PNPM_HOME="$HOME/.local/share/pnpm"
export PATH="$PNPM_HOME:$PATH"
[[ ":$PATH:" != *":$PNPM_HOME:"* ]] && export PATH="$PATH:$PNPM_HOME"
if [ -f /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
export PATH="$PATH:$HOME/apps"
export PATH="$PATH:$HOME/.remote-code/bin"
export PATH="$HOME/.local/bin:$PATH"
export ANDROID_SDK_ROOT="$HOME/Android/Sdk"
export ANDROID_NDK_HOME="$ANDROID_SDK_ROOT/ndk/27.3.13750724"
export ANDROID_HOME="$ANDROID_SDK_ROOT"

# Proton Pass CLI — secret reference paths for notify.js (pass-cli run --env-file).
export PUSHOVER_TOKEN_PASS_REF="pass://CLI/pushover-codex/token"
export PUSHOVER_USER_PASS_REF="pass://CLI/pushover-codex/user"

# Proton Pass CLI storage backend.
# Prefer filesystem key provider on Linux to avoid keyring/env drift.
export PROTON_PASS_KEY_PROVIDER="${PROTON_PASS_KEY_PROVIDER:-fs}"

# Optional local-only overrides (not in chezmoi templates).
if [ -f "$HOME/.config/proton-pass/key.env" ]; then
  . "$HOME/.config/proton-pass/key.env"
fi

# Cargo
if [ -f "$HOME/.cargo/env" ]; then
  . "$HOME/.cargo/env"
fi

# Phantom
if command -v phantom &> /dev/null; then
  eval "$(phantom completion zsh)"
fi

# Functions
function google() {
  gemini -p "指定したクエリを検索し、要約して。<query>$1</query>"
}

# --- CLI wrappers with chezmoi protonPass template resolution ---
# Secrets are resolved at chezmoi apply time via protonPass template function.
# This avoids pass-cli run, which does not preserve TTY stdin for interactive CLIs.

glm() {
  ANTHROPIC_AUTH_TOKEN='{{ protonPass "pass://CLI/z-ai-api-key-claude-code/credential" | trim }}' \
    ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic" \
    ANTHROPIC_DEFAULT_HAIKU_MODEL="glm-5-turbo" \
    ANTHROPIC_DEFAULT_SONNET_MODEL="glm-5-turbo" \
    ANTHROPIC_DEFAULT_OPUS_MODE="glm-5.1" \
    claude --dangerously-skip-permissions "$@"
}

cx() {
  CONTEXT7_API_KEY='{{ protonPass "pass://CLI/context7-api-key/APIキー" | trim }}' \
    codex "$@"
}

gog_op() {
  local keyring_password

  if ! command -v gog >/dev/null 2>&1; then
    echo "gog CLI is required." >&2
    return 1
  fi
  GOG_KEYRING_PASSWORD='{{ protonPass "pass://CLI/GOG_KEYRING_PASSWORD/認証情報" | trim }}' \
    gog "$@"
}

linear() {
  LINEAR_API_KEY='{{ protonPass "pass://CLI/linear-cli-api-key/APIキー" | trim }}' \
    linear "$@"
}

# Context7 / Codex config - pass-cli inject
_codex_tpl="$HOME/.codex/private_config.toml.template"
_codex_out="$HOME/.codex/private_config.toml"
if [ -f "$_codex_tpl" ] && command -v pass-cli >/dev/null 2>&1; then
  pass-cli inject --in-file "$_codex_tpl" --out-file "$_codex_out" --force 2>/dev/null
fi


# Aliases (kept due to command name conflicts)
alias cc="claude"
alias python="python3"
alias gog="gog_op"

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# pnpm completions
if command -v pnpm &> /dev/null; then
  eval "$(pnpm completion zsh)";
fi

# jujutsu completions
if command -v jj >/dev/null 2>&1; then
  source <(COMPLETE=zsh jj)
fi

# neovim
if [ -f "$HOME/apps/nvim-linux-arm64.appimage" ]; then
  alias nvim="$HOME/apps/nvim-linux-arm64.appimage"
fi

# Zellij custom
zll_new_git_wt() {
  # zellij 内でなければ終了
  if [ -z "${ZELLIJ-}" ]; then
    echo 'zj_new_tab: must be run inside zellij' >&2
    return 1
  fi

  # ブランチ名を受け取る
  local name="$1"

  if [ -z "$name" ]; then
    printf 'tab name: '
    read -r name || return 1
  fi

  [ -z "$name" ] && return 1

  phantom create "feature/$name"

  # Layout の作業領域が2ペイン前提
  local cwd="$PWD"
  zellij action new-tab --name "$name" --layout main --cwd "$cwd"

  zellij action write-chars "phantom shell feature/$name"
  zellij action write 13

  zellij action focus-next-pane
  zellij action write-chars "phantom shell feature/$name"
  zellij action write 13

  zellij action focus-previous-pane
  zellij action write-chars "codex"
  zellij action write 13
}

# zoxide
eval "$(zoxide init zsh --cmd z)"

# The next line updates PATH for the Google Cloud SDK.
if [ -f "$HOME/.local/share/google-cloud-sdk/path.zsh.inc" ]; then . "$HOME/.local/share/google-cloud-sdk/path.zsh.inc"; fi

# The next line enables shell command completion for gcloud.
if [ -f "$HOME/.local/share/google-cloud-sdk/completion.zsh.inc" ]; then . "$HOME/.local/share/google-cloud-sdk/completion.zsh.inc"; fi

# Keep mise-managed tools ahead of PATH entries added earlier in this file.
eval "$(mise activate zsh)"
eval "$(direnv hook zsh)"
