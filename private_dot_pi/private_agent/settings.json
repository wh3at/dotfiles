{
  "lastChangelogVersion": "0.81.1",
  "theme": "dark",
  "defaultProvider": "zai",
  "defaultModel": "glm-5.2",
  "defaultThinkingLevel": "low",
  "packages": [
    "git:github.com/EveryInc/compound-engineering-plugin",
    "npm:pi-subagents",
    "npm:pi-ask-user",
    "npm:pi-web-access",
    "npm:pi-hashline-edit",
    "npm:pi-mcp-adapter",
    "npm:@juicesharp/rpiv-todo",
    "git:github.com/championswimmer/pi-context-usage",
    "git:github.com/algal/pi-openai-server-compaction"
  ],
  "retry": {
    "enabled": true,
    "maxRetries": 5,
    "baseDelayMs": 3000
  },
  "subagents": {
    "defaultModel": "cursor/grok-4.5:high",
    "agentOverrides": {
      "scout": {
        "model": "corsor/grok-4.5:medium",
        "fallbackModels": [
          "gpt-5.6-luna:high"
        ]
      },
      "researcher": {
        "model": "cursor/grok-4.5:medium",
        "fallbackModels": [
          "gpt-5.6-luna:high"
        ]
      },
      "context-builder": {
        "model": "cursor/grok-4.5:medium",
        "fallbackModels": [
          "gpt-5.6-luna:high"
        ]
      },
      "delegate": {
        "fallbackModels": [
          "gpt-5.6-luna:xhigh"
        ]
      },
      "planner": {
        "fallbackModels": [
          "gpt-5.6-sol:low"
        ]
      },
      "worker": {
        "fallbackModels": [
          "gpt-5.6-luna:xhigh"
        ]
      },
      "reviewer": {
        "model": "gpt-5.6-sol",
        "thinking": "low"
      },
      "oracle": {
        "model": "gpt-5.6-sol",
        "thinking": "low"
      }
    }
  },
  "collapseChangelog": true
}
